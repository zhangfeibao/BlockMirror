{
  "name": "@blockpy-edu/blockmirror",
  "version": "2.0.0",
  "description": "A dual block/text editor using Blockly and CodeMirror for Python",
  "main": "electron/main.js",
  "scripts": {
    "build": "webpack --mode production",
    "devbuild": "webpack --mode development",
    "watch": "webpack --watch --mode development",
    "electron:start": "electron .",
    "pack:win": "electron-builder --win --x64"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blockpy-edu/BlockMirror.git"
  },
  "author": "acbart",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/blockpy-edu/BlockMirror/issues"
  },
  "homepage": "https://github.com/blockpy-edu/BlockMirror#readme",
  "devDependencies": {
    "@babel/cli": "^7.10.5",
    "@babel/core": "^7.11.1",
    "@babel/plugin-transform-runtime": "^7.11.0",
    "@babel/preset-env": "^7.11.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^8.1.0",
    "babel-plugin-add-module-exports": "^1.0.2",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "elliptic": "^6.5.3",
    "lodash": ">=4.17.19",
    "uglify-js": "^3.10.1",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0",
    "webpack-merge-and-include-globally": "^2.1.25",
    "yargs": "^15.4.1"
  },
  "build": {
    "appId": "com.blockmirror.app",
    "productName": "MideaBlockly",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "test/simple_v2.html",
      "dist/**/*",
      "lib/**/*",
      "blockfactory/**/*",
      "custom-modules/**/*",
      "advanced-terminal/**/*",
      "node_modules/blockly/**/*",
      "node_modules/@blockly/**/*",
      "node_modules/@xterm/**/*"
    ],
    "extraResources": [
      {
        "from": "python-embedded",
        "to": "python-embedded"
      },
      {
        "from": "ramgs",
        "to": "ramgs"
      },
      {
        "from": "VSCode",
        "to": "VSCode"
      },
      {
        "from": "device_api",
        "to": "device_api"
      }
    ],
    "win": {
      "target": "dir"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/blockly/media/**/*",
      "node_modules/node-pty/**/*"
    ]
  },
  "dependencies": {
    "@blockly/field-multilineinput": "^5.0.13",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "blockly": "^11.2.1",
    "node-pty": "^1.1.0"
  }
}
